// https://github.com/Azure/azure-mcp?tab=readme-ov-file#-manual-install
{
  "servers": {
    "Azure MCP Server": {
      "command": "npx",
      "args": [
        "-y",
        "@azure/mcp@latest",
        "server",
        "start"
      ]
    },
    "azureDevOps": {
      "command": "npx",
      "args": [
        "-y",
        "@tiberriver256/mcp-server-azure-devops"
      ],
      "env": {
        "AZURE_DEVOPS_ORG_URL": "https://dev.azure.com/autocloudarc-mcaps",
        "AZURE_DEVOPS_AUTH_METHOD": "interactive",
        "AZURE_DEVOPS_DEFAULT_PROJECT": "ado-pipeline-demos"
      }
    },
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest"
      ]
    },
    "tasksync": {
      "command": "npx",
      "type": "stdio",
      "args": [
        "-y",
        "tasksync-mcp@latest",
        "/path/to/directory"
      ]
    }
  }
}