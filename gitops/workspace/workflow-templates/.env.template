# Environment Configuration Template for .NET CI/CD
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to version control

# =============================================================================
# Azure Service Principal Configuration
# =============================================================================
# Create a service principal using: az ad sp create-for-rbac --name "github-actions-{project-name}" --role contributor
AZURE_CLIENT_ID=your-azure-client-id-here
AZURE_CLIENT_SECRET=your-azure-client-secret-here
AZURE_TENANT_ID=your-azure-tenant-id-here
AZURE_SUBSCRIPTION_ID=your-azure-subscription-id-here

# =============================================================================
# Development Environment Configuration
# =============================================================================
AZURE_WEBAPP_NAME_DEV=your-webapp-name-dev
AZURE_RESOURCE_GROUP_DEV=your-resource-group-dev
AZURE_WEBAPP_SLOT_DEV=staging

# =============================================================================
# QA Environment Configuration
# =============================================================================
AZURE_WEBAPP_NAME_QA=your-webapp-name-qa
AZURE_RESOURCE_GROUP_QA=your-resource-group-qa
AZURE_WEBAPP_SLOT_QA=staging

# =============================================================================
# Production Environment Configuration
# =============================================================================
AZURE_WEBAPP_NAME_PROD=your-webapp-name-prod
AZURE_RESOURCE_GROUP_PROD=your-resource-group-prod
AZURE_WEBAPP_SLOT_PROD=production

# =============================================================================
# GitHub Configuration
# =============================================================================
GITHUB_OWNER=your-github-username-or-org
GITHUB_REPO=your-repository-name
GITHUB_TOKEN=your-github-personal-access-token

# =============================================================================
# Optional: Database Configuration
# =============================================================================
# DATABASE_CONNECTION_STRING_DEV=your-dev-database-connection-string
# DATABASE_CONNECTION_STRING_QA=your-qa-database-connection-string
# DATABASE_CONNECTION_STRING_PROD=your-prod-database-connection-string

# =============================================================================
# Optional: Application Insights Configuration
# =============================================================================
# APPINSIGHTS_INSTRUMENTATION_KEY_DEV=your-dev-appinsights-key
# APPINSIGHTS_INSTRUMENTATION_KEY_QA=your-qa-appinsights-key
# APPINSIGHTS_INSTRUMENTATION_KEY_PROD=your-prod-appinsights-key

# =============================================================================
# Optional: Custom Application Settings
# =============================================================================
# CUSTOM_SETTING_1=value1
# CUSTOM_SETTING_2=value2
# CUSTOM_SETTING_3=value3
