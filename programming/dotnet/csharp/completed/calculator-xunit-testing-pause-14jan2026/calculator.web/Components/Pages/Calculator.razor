@page "/"
@using calculator.shared
@inject ICalculatorService CalculatorService

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-body">
                    <h1 class="card-title mb-4">Calculator</h1>

                    <form @onsubmit="HandleCalculate">
                        <div class="mb-3">
                            <label for="firstNumber" class="form-label">First Number</label>
                            <input 
                                type="number" 
                                step="any"
                                class="form-control" 
                                id="firstNumber"
                                @bind="FirstNumber"
                                placeholder="Enter first number" 
                                required />
                        </div>

                        <div class="mb-3">
                            <label for="secondNumber" class="form-label">Second Number</label>
                            <input 
                                type="number" 
                                step="any"
                                class="form-control" 
                                id="secondNumber"
                                @bind="SecondNumber"
                                placeholder="Enter second number" 
                                required />
                        </div>

                        <div class="mb-3">
                            <label for="operator" class="form-label">Operator</label>
                            <select class="form-select" id="operator" @bind="SelectedOperator" required>
                                <option value="">-- Select an operator --</option>
                                @foreach (var op in CalculatorService.GetSupportedOperators())
                                {
                                    <option value="@op">@op</option>
                                }
                            </select>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 mb-3">Calculate</button>
                    </form>

                    @if (!string.IsNullOrEmpty(ErrorMessage))
                    {
                        <div class="alert alert-danger" role="alert">
                            @ErrorMessage
                        </div>
                    }

                    @if (ShowResult)
                    {
                        <div class="alert alert-success" role="alert">
                            <strong>Result:</strong> @FirstNumber @SelectedOperator @SecondNumber = <span class="h5">@Result</span>
                        </div>
                    }

                    @if (CalculationHistory.Count > 0)
                    {
                        <div class="mt-4">
                            <h5>Calculation History</h5>
                            <div class="list-group">
                                @foreach (var calc in CalculationHistory.Take(10))
                                {
                                    <div class="list-group-item">
                                        @calc
                                    </div>
                                }
                            </div>
                            @if (CalculationHistory.Count > 10)
                            {
                                <small class="text-muted">... and @(CalculationHistory.Count - 10) more</small>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private double FirstNumber { get; set; } = 0;
    private double SecondNumber { get; set; } = 0;
    private string SelectedOperator { get; set; } = string.Empty;
    private double Result { get; set; } = 0;
    private bool ShowResult { get; set; } = false;
    private string ErrorMessage { get; set; } = string.Empty;
    private List<string> CalculationHistory { get; set; } = new();

    private void HandleCalculate()
    {
        ErrorMessage = string.Empty;
        ShowResult = false;

        if (string.IsNullOrWhiteSpace(SelectedOperator))
        {
            ErrorMessage = "Please select an operator.";
            return;
        }

        if (!CalculatorService.IsValidOperator(SelectedOperator))
        {
            ErrorMessage = $"'{SelectedOperator}' is not a valid operator.";
            return;
        }

        Result = CalculatorService.Calculate(FirstNumber, SecondNumber, SelectedOperator);

        if (double.IsNaN(Result))
        {
            ErrorMessage = "Invalid calculation result.";
            return;
        }

        if (double.IsInfinity(Result))
        {
            ErrorMessage = "Cannot divide by zero.";
            return;
        }

        string historyEntry = $"{FirstNumber} {SelectedOperator} {SecondNumber} = {Result}";
        CalculationHistory.Insert(0, historyEntry);
        ShowResult = true;
    }
}
