@page "/testcases"
@using CalculatorBlazor.Services
@using CalculatorBlazor.Data
@inject CalculatorDatabaseService DatabaseService

<PageTitle>Test Cases</PageTitle>

<h1>Calculator Test Cases</h1>

<p>Test cases loaded from SQLite database.</p>

@if (testCases == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="mb-3">
        <label for="operationFilter" class="form-label">Filter by Operation:</label>
        <select id="operationFilter" class="form-select" @onchange="OnOperationFilterChanged">
            <option value="">All Operations</option>
            <option value="Add">Add</option>
            <option value="Subtract">Subtract</option>
            <option value="Multiply">Multiply</option>
            <option value="Divide">Divide</option>
            <option value="Modulo">Modulo</option>
            <option value="Exponent">Exponent</option>
        </select>
    </div>

    <p>Showing <strong>@testCases.Count</strong> test case(s)</p>

    <table class="table table-striped">
        <thead>
            <tr>
                <th>ID</th>
                <th>First Number</th>
                <th>Operation</th>
                <th>Second Number</th>
                <th>Expected Value</th>
                <th>Description</th>
                <th>Result</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var testCase in testCases)
            {
                <tr>
                    <td>@testCase.Id</td>
                    <td>@testCase.FirstNumber</td>
                    <td><span class="badge bg-primary">@testCase.Operation</span></td>
                    <td>@testCase.SecondNumber</td>
                    <td>@testCase.ExpectedValue</td>
                    <td>@testCase.Description</td>
                    <td>
                        @if (testCase.Result == "passed")
                        {
                            <span class="badge bg-success">@testCase.Result</span>
                        }
                        else if (testCase.Result == "failed")
                        {
                            <span class="badge bg-danger">@testCase.Result</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">@testCase.Result</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<CalculatorTestCase>? testCases;
    private string selectedOperation = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadTestCases();
    } // end OnInitializedAsync

    private async Task LoadTestCases()
    {
        if (string.IsNullOrEmpty(selectedOperation))
        {
            testCases = await DatabaseService.GetAllTestCasesAsync();
        }
        else
        {
            testCases = await DatabaseService.GetTestCasesByOperationAsync(selectedOperation);
        } // end if
    } // end LoadTestCases

    private async Task OnOperationFilterChanged(ChangeEventArgs e)
    {
        selectedOperation = e.Value?.ToString() ?? string.Empty;
        await LoadTestCases();
    } // end OnOperationFilterChanged
} // end code
