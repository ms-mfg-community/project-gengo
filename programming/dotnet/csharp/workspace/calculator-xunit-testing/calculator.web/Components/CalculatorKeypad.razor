@namespace CalculatorWeb.Components
@using CalculatorWeb.Services

<div class="keypad">
    <!-- Row 0: Clear & Reset buttons -->
    <button class="btn btn-clear" @onclick='@(async () => await OnClear.InvokeAsync())'>
        <span class="btn-label">C</span>
        <span class="btn-sublabel">Clear</span>
    </button>
    <button class="btn btn-reset" @onclick='@(async () => await OnClear.InvokeAsync())' style="grid-column: span 3;">
        <span class="btn-label">RESET</span>
    </button>

    <!-- Row 1: 7 8 9 / -->
    <button class="btn btn-number" @onclick='@(async () => await OnNumberClick.InvokeAsync("7"))'>7</button>
    <button class="btn btn-number" @onclick='@(async () => await OnNumberClick.InvokeAsync("8"))'>8</button>
    <button class="btn btn-number" @onclick='@(async () => await OnNumberClick.InvokeAsync("9"))'>9</button>
    <button class="btn btn-operator" @onclick='@(async () => await OnOperatorClick.InvokeAsync("/"))' title="Divide">÷</button>

    <!-- Row 2: 4 5 6 * -->
    <button class="btn btn-number" @onclick='@(async () => await OnNumberClick.InvokeAsync("4"))'>4</button>
    <button class="btn btn-number" @onclick='@(async () => await OnNumberClick.InvokeAsync("5"))'>5</button>
    <button class="btn btn-number" @onclick='@(async () => await OnNumberClick.InvokeAsync("6"))'>6</button>
    <button class="btn btn-operator" @onclick='@(async () => await OnOperatorClick.InvokeAsync("*"))' title="Multiply">×</button>

    <!-- Row 3: 1 2 3 - -->
    <button class="btn btn-number" @onclick='@(async () => await OnNumberClick.InvokeAsync("1"))'>1</button>
    <button class="btn btn-number" @onclick='@(async () => await OnNumberClick.InvokeAsync("2"))'>2</button>
    <button class="btn btn-number" @onclick='@(async () => await OnNumberClick.InvokeAsync("3"))'>3</button>
    <button class="btn btn-operator" @onclick='@(async () => await OnOperatorClick.InvokeAsync("-"))' title="Subtract">−</button>

    <!-- Row 4: 0 . + -->
    <button class="btn btn-number btn-zero" @onclick='@(async () => await OnNumberClick.InvokeAsync("0"))' style="grid-column: span 2;">0</button>
    <button class="btn btn-number" @onclick='@(async () => await OnNumberClick.InvokeAsync("."))'>.</button>
    <button class="btn btn-operator" @onclick='@(async () => await OnOperatorClick.InvokeAsync("+"))' title="Add">+</button>

    <!-- Row 5: x^y = -->
    <button class="btn btn-operator" @onclick='@(async () => await OnOperatorClick.InvokeAsync("^"))' style="grid-column: span 2;" title="Power">x<sup>y</sup></button>
    <button class="btn btn-equals" @onclick='@(async () => await OnEquals.InvokeAsync())' style="grid-column: span 2;">=</button>
</div>

@code {
    [Parameter]
    public EventCallback<string> OnNumberClick { get; set; }

    [Parameter]
    public EventCallback<string> OnOperatorClick { get; set; }

    [Parameter]
    public EventCallback OnEquals { get; set; }

    [Parameter]
    public EventCallback OnClear { get; set; }
}
