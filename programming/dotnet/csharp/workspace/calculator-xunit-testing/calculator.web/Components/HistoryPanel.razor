@namespace CalculatorWeb.Components
@using CalculatorWeb.Models

<div class="history-panel">
    <div class="history-header">
        <h3>History</h3>
        @if (!IsEmpty)
        {
            <button class="btn-clear-history" @onclick='@(async () => await OnClearHistory.InvokeAsync())' title="Clear history">✕</button>
        }
    </div>

    <div class="history-list">
        @if (IsEmpty)
        {
            <p class="history-empty">No calculations yet</p>
        }
        else if (Calculations != null)
        {
            @foreach (var (calculation, index) in Calculations.Select((c, i) => (c, i)))
            {
                <div class="history-item" @onclick='@(async () => await OnReplay.InvokeAsync(index))'>
                    <span class="history-text">@calculation.DisplayText</span>
                </div>
            }
        }
    </div>
</div>

@code {
    [Parameter]
    public IReadOnlyList<CalculationRecord>? Calculations { get; set; }

    [Parameter]
    public bool IsEmpty { get; set; }

    [Parameter]
    public EventCallback<int> OnReplay { get; set; }

    [Parameter]
    public EventCallback OnClearHistory { get; set; }
}
