@using calculator.web.Services

<div class="history-panel">
    <h3>History</h3>
    @if (Items.Count == 0)
    {
        <p class="history-empty">No calculations yet.</p>
    }
    else
    {
        <ul class="history-list">
            @foreach (var record in Items)
            {
                <li class="history-item" @onclick="() => OnReplay(record)" title="Click to replay">
                    @record.ToString()
                </li>
            }
        </ul>
    }
</div>

@code {
    /// <summary>The list of calculation records to display.</summary>
    [Parameter]
    public IReadOnlyList<CalculationRecord> Items { get; set; } = Array.Empty<CalculationRecord>();

    /// <summary>Callback when a history item is clicked for replay.</summary>
    [Parameter]
    public EventCallback<CalculationRecord> OnReplayClicked { get; set; }

    private async Task OnReplay(CalculationRecord record)
    {
        await OnReplayClicked.InvokeAsync(record);
    }
}
